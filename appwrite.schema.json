{
  "tables": [
    {
      "id": "profiles",
      "name": "profiles",
      "columns": [
        { "key": "userId", "type": "varchar", "size": 64, "required": true },
        { "key": "username", "type": "varchar", "size": 32 },
        {
          "key": "niche",
          "type": "enum",
          "elements": ["glamour", "fitness", "cosplay", "sensual"]
        },
        { "key": "avatarFileId", "type": "varchar", "size": 64 },
        { "key": "bannerFileId", "type": "varchar", "size": 64 },
        { "key": "contentFileIds", "type": "varchar", "size": 64, "array": true },
        { "key": "bgGradient", "type": "varchar", "size": 512 },
        {
          "key": "botGoal",
          "type": "enum",
          "elements": ["maximize_tokens", "drive_subscriptions", "warm_fanbase"]
        },
        { "key": "onboardingComplete", "type": "boolean", "default": false }
      ],
      "indexes": [
        { "key": "idx_userId", "type": "unique", "columns": ["userId"] },
        { "key": "idx_username", "type": "unique", "columns": ["username"] }
      ]
    },
    {
      "id": "content",
      "name": "content",
      "columns": [
        { "key": "userId", "type": "varchar", "size": 64, "required": true },
        {
          "key": "contentType",
          "type": "enum",
          "elements": ["file", "discount", "event", "perk"],
          "required": true
        },
        {
          "key": "tier",
          "type": "enum",
          "elements": ["exclusive", "gamble"],
          "required": true
        },
        {
          "key": "rarity",
          "type": "enum",
          "elements": ["common", "rare", "epic", "legendary"]
        },
        { "key": "tokenValue", "type": "integer", "min": 0, "max": 1000000 },
        { "key": "title", "type": "varchar", "size": 120 },
        { "key": "description", "type": "varchar", "size": 1000 },
        { "key": "fileId", "type": "varchar", "size": 64 },
        {
          "key": "mediaType",
          "type": "enum",
          "elements": ["image", "video"]
        },
        { "key": "discountPercent", "type": "integer", "min": 0, "max": 100 },
        { "key": "eventAt", "type": "varchar", "size": 40 },
        { "key": "eventLocation", "type": "varchar", "size": 300 },
        { "key": "collectionId", "type": "varchar", "size": 64 }
      ],
      "indexes": [
        { "key": "idx_content_user", "type": "key", "columns": ["userId"] }
      ]
    },
    {
      "id": "collections",
      "name": "collections",
      "columns": [
        { "key": "userId", "type": "varchar", "size": 64, "required": true },
        {
          "key": "tier",
          "type": "enum",
          "elements": ["exclusive", "gamble"],
          "required": true
        },
        { "key": "name", "type": "varchar", "size": 60, "required": true },
        { "key": "visible", "type": "boolean", "required": false, "default": true }
      ],
      "indexes": [
        { "key": "idx_collections_user", "type": "key", "columns": ["userId"] }
      ]
    },
    {
      "id": "subscription_tiers",
      "name": "subscription_tiers",
      "columns": [
        { "key": "userId", "type": "varchar", "size": 64, "required": true },
        { "key": "name", "type": "varchar", "size": 40, "required": true },
        { "key": "tagline", "type": "varchar", "size": 120 },
        { "key": "description", "type": "varchar", "size": 1000 },
        { "key": "priceCents", "type": "integer", "min": 0, "max": 100000000, "required": true },
        {
          "key": "currency",
          "type": "enum",
          "elements": ["usd", "eur", "gbp"]
        },
        {
          "key": "billingPeriod",
          "type": "enum",
          "elements": ["monthly", "quarterly", "yearly"]
        },
        { "key": "includedCollectionIds", "type": "varchar", "size": 64, "array": true },
        { "key": "unlocksAllExclusive", "type": "boolean", "default": false },
        { "key": "benefits", "type": "varchar", "size": 120, "array": true },
        { "key": "coverFileId", "type": "varchar", "size": 64 },
        { "key": "trialDays", "type": "integer", "min": 0, "max": 90 },
        { "key": "introDiscountPercent", "type": "integer", "min": 0, "max": 100 },
        { "key": "introLabel", "type": "varchar", "size": 60 },
        { "key": "subscriberCap", "type": "integer", "min": 0, "max": 1000000 },
        { "key": "visible", "type": "boolean", "default": true },
        { "key": "sortOrder", "type": "integer", "min": 0, "max": 1000, "default": 0 }
      ],
      "indexes": [
        { "key": "idx_subtiers_user", "type": "key", "columns": ["userId"] }
      ]
    },
    {
      "id": "subscriptions",
      "name": "subscriptions",
      "columns": [
        { "key": "fanUserId", "type": "varchar", "size": 64, "required": true },
        { "key": "creatorUserId", "type": "varchar", "size": 64, "required": true },
        { "key": "tierId", "type": "varchar", "size": 64, "required": true },
        {
          "key": "status",
          "type": "enum",
          "elements": ["active", "trialing", "past_due", "canceled", "expired"],
          "required": true
        },
        { "key": "startedAt", "type": "varchar", "size": 40 },
        { "key": "currentPeriodEnd", "type": "varchar", "size": 40 },
        { "key": "cancelAtPeriodEnd", "type": "boolean", "default": false },
        { "key": "providerSubscriptionId", "type": "varchar", "size": 128 },
        { "key": "providerCustomerId", "type": "varchar", "size": 128 }
      ],
      "indexes": [
        { "key": "idx_subs_fan", "type": "key", "columns": ["fanUserId"] },
        {
          "key": "idx_subs_creator_status",
          "type": "key",
          "columns": ["creatorUserId", "status"]
        }
      ]
    }
  ]
}
